# Set the default behavior to handle all files as text and normalize line endings to LF on commit.
* text=auto

# Declare files that will always have LF line endings on checkout.
# This prevents shell scripts, config files, and JS/JSON files from getting CRLF line endings on Windows, which breaks them on Linux.
*.sh text eol=lf
*.bash text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
.env* text eol=lf
Dockerfile* text eol=lf
docker-compose* text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.mov binary
*.mp4 binary
*.otf binary
*.ttf binary
*.woff binary
*.woff2 binary
