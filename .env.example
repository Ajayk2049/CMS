# ==============================================================================
# CMS PLATFORM - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy this file to 'server/config/.env.dev' for local testing, 
# or to 'server/config/.env.prod' for live servers.
# ==============================================================================

# 1. Server Ports Configuration
PORT=5000
GRPC_PORT=50051

# 2. Database & Caching Configurations
MONGO_URI=mongodb://localhost:27017/cms_db
REDIS_HOST=localhost
REDIS_PORT=6379

# 3. Security Credentials
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# 4. Authentication & SMS API Configurations (StartMessaging)
DEMO_MODE=true
DEMO_PHONE=9876543210
DEMO_OTP=123456
STARTMESSAGING_API_KEY=sm_live_your_key_here
OTP_TEMPLATE_ID=your-uuid-template-id-here

# 5. Payment Gateway Configuration (PhonePe V2 Checkout)
PHONEPE_MERCHANT_ID=PGTESTPAYUAT
PHONEPE_CLIENT_ID=your_oauth_client_id_here
PHONEPE_CLIENT_SECRET=your_oauth_client_secret_here
PHONEPE_AUTH_URL=https://mercury-uat.phonepe.com
PHONEPE_HOST_URL=https://mercury-uat.phonepe.com
PHONEPE_CALLBACK_URL=http://localhost:5000/api/v1/payments/callback
PHONEPE_WEBHOOK_USER=cms_webhook
PHONEPE_WEBHOOK_PASSWORD=webhook_secure_pass_123
